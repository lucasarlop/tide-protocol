#!/usr/bin/env python3
"""tide-taiga — optional Taiga integration for Tide Protocol."""
from __future__ import annotations

import argparse
import getpass
import json
import platform
import re
import subprocess
import sys
from collections import Counter
from datetime import date, datetime
from pathlib import Path
from typing import Any
from urllib.error import HTTPError, URLError
from urllib.parse import urlencode
from urllib.request import Request, urlopen

CONFIG_DIR = Path.home() / ".config" / "tide" / "taiga"
CONFIG_FILE = CONFIG_DIR / "config.json"
LOCAL_TOKEN_FILE = CONFIG_DIR / "token"
KEYCHAIN_SERVICE = "tide-taiga"
KEYCHAIN_ACCOUNT = "default"
REQUEST_TIMEOUT = 20
DEFAULT_KIND = "userstory"
ENTITY_ALIASES = {
    "board": "userstories",
    "story": "userstories",
    "us": "userstories",
    "userstory": "userstories",
    "userstories": "userstories",
    "task": "tasks",
    "tasks": "tasks",
    "issue": "issues",
    "issues": "issues",
}
STATUS_ENDPOINT = {
    "tasks": "task-statuses",
    "userstories": "userstory-statuses",
    "issues": "issue-statuses",
}
STATUS_ALIASES = {
    "doing": ["doing", "in progress", "in-progress", "em andamento", "andamento", "em desenvolvimento", "desenvolvimento", "working", "wip"],
    "done": ["done", "closed", "concluido", "concluído", "finalizado", "feito", "pronto", "resolved", "complete", "completed"],
    "todo": ["todo", "to do", "open", "new", "nova", "novo", "backlog", "a fazer", "pendente"],
}


def die(message: str, code: int = 1) -> None:
    print(f"erro: {message}", file=sys.stderr)
    raise SystemExit(code)


def command_output(args: list[str]) -> tuple[int, str]:
    try:
        result = subprocess.run(args, text=True, capture_output=True)
    except OSError as exc:
        return 127, str(exc)
    return result.returncode, (result.stdout or result.stderr or "").strip()


def has_command(name: str) -> bool:
    from shutil import which

    return which(name) is not None


def read_stdin_text(label: str) -> str:
    if sys.stdin.isatty():
        die(f"{label} por stdin solicitado, mas stdin está vazio")
    return sys.stdin.read()


def read_json(path: Path, default: Any | None = None) -> Any:
    if not path.exists():
        if default is not None:
            return default
        die(f"arquivo não encontrado: {path}")
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except json.JSONDecodeError as exc:
        die(f"JSON inválido em {path}: {exc}")


def write_json(path: Path, data: Any) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(data, indent=2, ensure_ascii=False) + "\n", encoding="utf-8")
    try:
        path.chmod(0o600)
    except OSError:
        pass


def print_json(data: Any) -> None:
    print(json.dumps(data, indent=2, ensure_ascii=False))


def load_config(required: bool = True) -> dict[str, Any]:
    config = read_json(CONFIG_FILE, {})
    if required and not config:
        die("Taiga não configurado; rode `tide taiga configure`")
    return config


def keychain_available() -> bool:
    return platform.system() == "Darwin" and has_command("security")


def save_token(token: str, *, allow_local_token: bool) -> str:
    if keychain_available():
        code = subprocess.call([
            "security", "add-generic-password",
            "-a", KEYCHAIN_ACCOUNT,
            "-s", KEYCHAIN_SERVICE,
            "-w", token,
            "-U",
        ], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        if code == 0:
            return "macos-keychain"
        print("warn: não foi possível gravar no macOS Keychain", file=sys.stderr)
    if not allow_local_token:
        die("Keychain indisponível. Repita com --allow-local-token para salvar token local chmod 600.")
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    LOCAL_TOKEN_FILE.write_text(token + "\n", encoding="utf-8")
    try:
        LOCAL_TOKEN_FILE.chmod(0o600)
    except OSError:
        pass
    return "local-file"


def read_token(config: dict[str, Any]) -> str:
    storage = config.get("token_storage")
    if storage == "macos-keychain":
        code, out = command_output([
            "security", "find-generic-password",
            "-a", KEYCHAIN_ACCOUNT,
            "-s", KEYCHAIN_SERVICE,
            "-w",
        ])
        if code == 0 and out:
            return out.strip()
        die("token Taiga não encontrado no Keychain; rode `tide taiga configure`")
    if storage == "local-file":
        if LOCAL_TOKEN_FILE.exists():
            token = LOCAL_TOKEN_FILE.read_text(encoding="utf-8").strip()
            if token:
                return token
        die("token local Taiga não encontrado; rode `tide taiga configure --allow-local-token`")
    die("token_storage ausente ou desconhecido; rode `tide taiga configure`")


def token_exists(config: dict[str, Any]) -> bool:
    try:
        return bool(read_token(config))
    except SystemExit:
        return False


def canonical_kind(kind: str | None) -> str:
    raw = kind or DEFAULT_KIND
    try:
        return ENTITY_ALIASES[str(raw).strip().lower()]
    except KeyError:
        die(f"tipo inválido: {raw}. Use userstory, task ou issue")


def public_kind(canonical: str) -> str:
    return {"tasks": "task", "userstories": "userstory", "issues": "issue"}.get(canonical, canonical)


def safe_dict(value: Any) -> dict[str, Any]:
    return value if isinstance(value, dict) else {}


def safe_extra(entity: dict[str, Any], key: str) -> dict[str, Any]:
    return safe_dict(entity.get(key))


def normalize_tag(value: Any) -> str | None:
    if value is None:
        return None
    if isinstance(value, (list, tuple)) and value:
        value = value[0]
    text = str(value).strip()
    return text or None


def taiga_web_base(config: dict[str, Any] | None = None) -> str:
    base_url = str((config or load_config(False)).get("base_url", "")).rstrip("/")
    return base_url.rsplit("/api/v1", 1)[0] if "/api/v1" in base_url else base_url


def entity_url(entity: dict[str, Any], kind: str | None = None, config: dict[str, Any] | None = None) -> str | None:
    ref = entity.get("ref")
    project_slug = safe_extra(entity, "project_extra_info").get("slug")
    if not ref or not project_slug:
        return None
    canonical = canonical_kind(kind or entity.get("type") or DEFAULT_KIND)
    web_kind = {"tasks": "task", "userstories": "us", "issues": "issue"}.get(canonical, public_kind(canonical))
    base = taiga_web_base(config)
    return f"{base}/project/{project_slug}/{web_kind}/{ref}" if base else None


def parse_due_date(value: str | None, *, no_due_date: bool = False) -> str | None:
    if no_due_date:
        return None
    raw = (value or "today").strip().lower()
    if raw in {"none", "null", "sem", "no", "no-date"}:
        return None
    if raw in {"today", "hoje"}:
        return date.today().isoformat()
    if not re.fullmatch(r"\d{4}-\d{2}-\d{2}", raw):
        die("data inválida; use today, none ou YYYY-MM-DD")
    return raw


def render_value(value: Any) -> str:
    if value is None:
        return "—"
    if isinstance(value, (dict, list)):
        return json.dumps(value, ensure_ascii=False)
    return str(value)


def render_text_block(title: str, value: str) -> list[str]:
    text = value.rstrip("\n")
    count = len(value.splitlines())
    return [
        f"### {title}",
        "",
        f"({len(value)} caracteres, {count} linhas)",
        "",
        "```text",
        text,
        "```",
        "",
    ]


def render_payload(payload: dict[str, Any] | None) -> list[str]:
    if not payload:
        return ["Nenhum campo informado.", ""]
    lines: list[str] = []
    text_fields: list[tuple[str, str]] = []
    for key, value in payload.items():
        if key in {"description", "comment"} and isinstance(value, str):
            text_fields.append((key, value))
        else:
            lines.append(f"- **{key}**: {render_value(value)}")
    if lines:
        lines.append("")
    for key, value in text_fields:
        title = "Descrição" if key == "description" else "Comentário"
        lines.extend(render_text_block(title, value))
    return lines


def render_target(target: dict[str, Any] | None) -> list[str]:
    if not target:
        return ["Novo item.", ""]
    keys = ["ref", "id", "subject", "status", "assigned_to", "project", "url"]
    lines = []
    for key in keys:
        if key in target and target.get(key) not in {None, ""}:
            lines.append(f"- **{key}**: {render_value(target.get(key))}")
    return lines + [""] if lines else ["Item existente identificado, sem campos resumidos disponíveis.", ""]


def text_summary(value: str) -> dict[str, Any]:
    lines = value.splitlines()
    return {
        "length": len(value),
        "lines": len(lines),
        "preview": value if len(value) <= 1200 else value[:1200] + "\n...[truncated]",
    }


def dry_run_payload(operation: str, kind: str, *, target: dict[str, Any] | None = None, payload: dict[str, Any] | list[Any] | None = None, note: str | None = None) -> dict[str, Any]:
    def safe_payload_item(item: Any) -> Any:
        if not isinstance(item, dict):
            return item
        safe: dict[str, Any] = {}
        for key, value in item.items():
            if key in {"description", "comment"} and isinstance(value, str):
                safe[key] = text_summary(value)
            else:
                safe[key] = value
        return safe

    return {
        "dry_run": True,
        "will_write": False,
        "operation": operation,
        "kind": public_kind(canonical_kind(kind)),
        "target": target,
        "payload": [safe_payload_item(x) for x in payload] if isinstance(payload, list) else safe_payload_item(payload or {}),
        "requires_next_step": "Peça autorização explícita ao supervisor; só depois execute novamente com --yes sem --dry-run.",
        "note": note,
    }


def dry_run_output(operation: str, kind: str, *, target: dict[str, Any] | None = None, payload: dict[str, Any] | list[Any] | None = None, note: str | None = None, json_output: bool = False) -> None:
    if json_output:
        print_json(dry_run_payload(operation, kind, target=target, payload=payload, note=note))
        return
    public = public_kind(canonical_kind(kind))
    lines = [
        "# Prévia de alteração no Taiga",
        "",
        "Nenhuma alteração foi enviada ao Taiga nesta execução.",
        "",
        "## Resumo",
        "",
        f"- **Operação**: {operation}",
        f"- **Tipo**: {public}",
        "- **Escrita agora**: não",
    ]
    if note:
        lines.append(f"- **Nota**: {note}")
    lines.extend(["", "## Alvo", ""])
    lines.extend(render_target(target))
    lines.extend(["## Campos propostos", ""])
    if isinstance(payload, list):
        for idx, item in enumerate(payload, 1):
            lines.extend([f"### Item {idx}", ""])
            lines.extend(render_payload(item if isinstance(item, dict) else {"value": item}))
    else:
        lines.extend(render_payload(payload if isinstance(payload, dict) else {}))
    lines.extend([
        "## Próximo passo",
        "",
        "Revise o conteúdo acima. Se estiver correto, autorize explicitamente e repita o mesmo comando com `--yes` e sem `--dry-run`.",
    ])
    print("\n".join(lines).rstrip() + "\n")


class TaigaClient:
    def __init__(self, config: dict[str, Any]):
        self.config = config
        self.base_url = str(config.get("base_url", "")).rstrip("/")
        if not self.base_url:
            die("base_url ausente; rode `tide taiga configure`")
        self.token = read_token(config)

    def request(self, method: str, endpoint: str, payload: dict[str, Any] | None = None, *, allow_not_found: bool = False) -> Any:
        endpoint = endpoint.lstrip("/")
        body = None if payload is None else json.dumps(payload, ensure_ascii=False).encode("utf-8")
        req = Request(
            f"{self.base_url}/{endpoint}",
            data=body,
            method=method.upper(),
            headers={
                "Authorization": f"Bearer {self.token}",
                "Content-Type": "application/json",
                "Accept": "application/json",
            },
        )
        try:
            with urlopen(req, timeout=REQUEST_TIMEOUT) as response:
                raw = response.read().decode("utf-8")
                if response.status == 204 or not raw:
                    return True
                return json.loads(raw)
        except HTTPError as exc:
            if allow_not_found and exc.code == 404:
                return None
            raw = exc.read().decode("utf-8", errors="replace")
            try:
                detail = json.loads(raw)
            except json.JSONDecodeError:
                detail = raw
            die(f"Taiga HTTP {exc.code}: {detail}")
        except (URLError, TimeoutError) as exc:
            die(f"falha ao conectar no Taiga: {exc}")

    def request_page(self, endpoint: str) -> tuple[Any, dict[str, str]]:
        req = Request(
            f"{self.base_url}/{endpoint.lstrip('/')}",
            method="GET",
            headers={"Authorization": f"Bearer {self.token}", "Accept": "application/json"},
        )
        try:
            with urlopen(req, timeout=REQUEST_TIMEOUT) as response:
                raw = response.read().decode("utf-8")
                data = json.loads(raw) if raw else []
                return data, {k.lower(): v for k, v in response.headers.items()}
        except HTTPError as exc:
            raw = exc.read().decode("utf-8", errors="replace")
            die(f"Taiga HTTP {exc.code}: {raw}")
        except (URLError, TimeoutError) as exc:
            die(f"falha ao conectar no Taiga: {exc}")

    def pages(self, endpoint: str) -> list[dict[str, Any]]:
        out: list[dict[str, Any]] = []
        page = 1
        while True:
            sep = "&" if "?" in endpoint else "?"
            data, headers = self.request_page(f"{endpoint}{sep}page={page}&page_size=200")
            if not data:
                break
            if not isinstance(data, list):
                die(f"endpoint paginado não retornou lista: {endpoint}")
            out.extend(data)
            next_header = headers.get("x-pagination-next") or headers.get("x-pagination-next-page")
            if next_header in {None, "", "None", "null"}:
                break
            page += 1
        return out

    def project_id(self, override: int | None = None) -> int:
        value = override or self.config.get("project_id")
        if not value:
            die("project_id ausente; use --project-id ou rode `tide taiga configure`")
        return int(value)

    def me(self) -> dict[str, Any]:
        return self.request("GET", "users/me")

    def projects(self) -> list[dict[str, Any]]:
        user = self.me()
        return self.pages(f"projects?member={user['id']}")

    def list_entities(self, kind: str, project_id: int | None = None) -> list[dict[str, Any]]:
        canonical = canonical_kind(kind)
        return self.pages(f"{canonical}?project={self.project_id(project_id)}")

    def search_entities(self, kind: str, *, subject: str | None = None, contains: str | None = None, project_id: int | None = None, limit: int | None = None) -> list[dict[str, Any]]:
        canonical = canonical_kind(kind)
        endpoint = f"{canonical}?project={self.project_id(project_id)}"
        if contains and not subject:
            endpoint += "&" + urlencode({"q": contains})
        items = [item for item in self.pages(endpoint) if entity_matches(item, subject=subject, contains=contains)]
        return items[:limit] if limit and limit > 0 else items

    def resolve_ref(self, kind: str, ref: int, project_id: int | None = None) -> dict[str, Any]:
        canonical = canonical_kind(kind)
        pid = self.project_id(project_id)
        by_ref = self.request("GET", f"{canonical}/by_ref?{urlencode({'project': pid, 'ref': ref})}", allow_not_found=True)
        if isinstance(by_ref, dict):
            return by_ref
        matches = [
            item for item in self.list_entities(canonical, pid)
            if str(item.get("ref")) == str(ref) or str(item.get("id")) == str(ref)
        ]
        if not matches:
            die(f"nenhum {public_kind(canonical)} encontrado para ref/id {ref}")
        if len(matches) > 1:
            die(f"ref ambígua {ref}: " + ", ".join(f"#{m.get('ref')} id={m.get('id')}" for m in matches))
        return matches[0]

    def get_entity(self, kind: str, entity_id: int) -> dict[str, Any]:
        return self.request("GET", f"{canonical_kind(kind)}/{entity_id}")

    def create_entity(self, kind: str, payload: dict[str, Any]) -> dict[str, Any]:
        return self.request("POST", canonical_kind(kind), payload)

    def patch_entity(self, kind: str, entity_id: int, payload: dict[str, Any]) -> dict[str, Any]:
        current = self.get_entity(kind, entity_id)
        body = {"version": current.get("version")}
        body.update(payload)
        return self.request("PATCH", f"{canonical_kind(kind)}/{entity_id}", body)

    def statuses(self, kind: str, project_id: int | None = None) -> list[dict[str, Any]]:
        canonical = canonical_kind(kind)
        return self.pages(f"{STATUS_ENDPOINT[canonical]}?project={self.project_id(project_id)}")

    def resolve_status_optional(self, kind: str, status_name: str, project_id: int | None = None) -> tuple[int, str] | None:
        statuses = self.statuses(kind, project_id)
        needle = status_name.strip().lower()
        candidates = [needle, *STATUS_ALIASES.get(needle, [])]
        for candidate in candidates:
            for status in statuses:
                if str(status.get("name", "")).strip().lower() == candidate:
                    return int(status["id"]), str(status.get("name"))
        for candidate in candidates:
            for status in statuses:
                name = str(status.get("name", "")).strip().lower()
                slug = str(status.get("slug", "")).strip().lower()
                if candidate in {slug, name.replace(" ", "-")}: 
                    return int(status["id"]), str(status.get("name"))
        return None

    def resolve_status(self, kind: str, status_name: str, project_id: int | None = None) -> tuple[int, str]:
        found = self.resolve_status_optional(kind, status_name, project_id)
        if found:
            return found
        names = ", ".join(str(s.get("name")) for s in self.statuses(kind, project_id))
        die(f"status não encontrado: {status_name}. Disponíveis: {names}")

    def members(self, project_id: int | None = None) -> list[dict[str, Any]]:
        return self.pages(f"users?project={self.project_id(project_id)}")

    def resolve_member(self, username: str, project_id: int | None = None) -> int:
        needle = username.strip().lower()
        for member in self.members(project_id):
            values = [member.get("username"), member.get("full_name"), member.get("name")]
            if any(str(value or "").strip().lower() == needle for value in values):
                return int(member["id"])
        die(f"membro não encontrado no projeto: {username}")


def client() -> TaigaClient:
    return TaigaClient(load_config(True))


def compact_entity(entity: dict[str, Any], *, kind: str | None = None) -> dict[str, Any]:
    status_info = safe_extra(entity, "status_extra_info")
    assignee_info = safe_extra(entity, "assigned_to_extra_info")
    project_info = safe_extra(entity, "project_extra_info")
    return {
        "id": entity.get("id"),
        "ref": entity.get("ref"),
        "subject": entity.get("subject"),
        "status": status_info.get("name") or entity.get("status"),
        "assigned_to": assignee_info.get("username") or assignee_info.get("full_name") or entity.get("assigned_to"),
        "project": project_info.get("slug") or entity.get("project"),
        "url": entity_url(entity, kind),
        "version": entity.get("version"),
        "description": entity.get("description", ""),
        "tags": entity.get("tags", []),
    }


def require_yes(args: argparse.Namespace, action: str) -> None:
    if not getattr(args, "yes", False):
        die(f"{action} altera o Taiga; repita com --yes após confirmação explícita")


def resolved_kind(args: argparse.Namespace) -> str:
    return canonical_kind(getattr(args, "kind", None) or DEFAULT_KIND)


def resolve_default_assignee(c: TaigaClient, args: argparse.Namespace, project_id: int) -> tuple[int | None, str | None]:
    if getattr(args, "no_assignee", False):
        return None, None
    if getattr(args, "assigned_to", None):
        return c.resolve_member(args.assigned_to, project_id), args.assigned_to
    user = c.me()
    return int(user["id"]), user.get("username") or user.get("full_name") or str(user.get("id"))


def apply_default_management_fields(c: TaigaClient, args: argparse.Namespace, canonical: str, project_id: int, payload: dict[str, Any], preview: dict[str, Any]) -> None:
    due = parse_due_date(getattr(args, "due_date", None), no_due_date=getattr(args, "no_due_date", False))
    if due:
        payload["due_date"] = due
        preview["due_date"] = due
    assigned_id, assigned_label = resolve_default_assignee(c, args, project_id)
    if assigned_id is not None:
        payload["assigned_to"] = assigned_id
        preview["assigned_to"] = assigned_label or assigned_id
    if not getattr(args, "no_status", False):
        status_name = getattr(args, "status", None) or "doing"
        found = c.resolve_status_optional(canonical, status_name, project_id)
        if found:
            payload["status"] = found[0]
            preview["status"] = found[1]
        elif getattr(args, "status", None):
            c.resolve_status(canonical, status_name, project_id)
        else:
            preview["status"] = "não definido: status 'doing' não encontrado no projeto"


def cmd_configure(args: argparse.Namespace) -> None:
    current = load_config(False)
    base_url = (args.base_url or current.get("base_url") or input("Taiga base URL: ")).strip().rstrip("/")
    project_id_raw = str(args.project_id or current.get("project_id") or input("Taiga project ID: ")).strip()
    default_kind = str(args.default_kind or DEFAULT_KIND).strip()
    canonical_kind(default_kind)
    if not base_url:
        die("base URL obrigatória")
    try:
        project_id = int(project_id_raw)
    except ValueError:
        die("project ID deve ser numérico")
    token = args.token or getpass.getpass("Taiga auth token: ").strip()
    if not token:
        die("token obrigatório")
    storage = save_token(token, allow_local_token=args.allow_local_token)
    write_json(CONFIG_FILE, {
        "base_url": base_url,
        "project_id": project_id,
        "default_kind": public_kind(canonical_kind(default_kind)),
        "token_storage": storage,
        "auto_sync": True,
        "auto_comment_on_finish": True,
        "auto_comment_on_commit": True,
        "auto_move_status": False,
        "default_due_date": "today",
        "default_assignee": "me",
        "default_status": "doing",
    })
    print("Taiga configurado")
    print(f"config : {CONFIG_FILE}")
    print(f"base   : {base_url}")
    print(f"project: {project_id}")
    print(f"kind   : {public_kind(canonical_kind(default_kind))}")
    print(f"token  : {storage}")


def cmd_doctor(_args: argparse.Namespace) -> None:
    config = load_config(False)
    print("Tide Taiga Doctor")
    print(f"config : {CONFIG_FILE}")
    if not config:
        print("[warn] config Taiga — não configurado; rode `tide taiga configure`")
        raise SystemExit(1)
    ok = True
    for key in ["base_url", "project_id", "default_kind", "token_storage"]:
        exists = key in config and config[key] not in {"", None}
        print(f"[{'ok' if exists else 'warn'}] {key}")
        ok = ok and exists
    has_token = token_exists(config)
    print(f"[{'ok' if has_token else 'warn'}] token — {config.get('token_storage', 'não configurado')}")
    ok = ok and has_token
    print(f"base   : {config.get('base_url', '')}")
    print(f"project: {config.get('project_id', '')}")
    print(f"kind   : {config.get('default_kind', '')}")
    print("Taiga Doctor: ok" if ok else "Taiga Doctor: há avisos")
    raise SystemExit(0 if ok else 1)


def cmd_show(_args: argparse.Namespace) -> None:
    config = load_config(False)
    if not config:
        die("Taiga não configurado")
    redacted = dict(config)
    redacted["token_present"] = token_exists(config)
    print_json(redacted)


def cmd_logout(_args: argparse.Namespace) -> None:
    config = load_config(False)
    if config.get("token_storage") == "macos-keychain" and keychain_available():
        subprocess.call(["security", "delete-generic-password", "-a", KEYCHAIN_ACCOUNT, "-s", KEYCHAIN_SERVICE], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    if LOCAL_TOKEN_FILE.exists():
        LOCAL_TOKEN_FILE.unlink()
    if CONFIG_FILE.exists():
        CONFIG_FILE.unlink()
    print("Taiga removido da configuração local")


def cmd_whoami(args: argparse.Namespace) -> None:
    user = client().me()
    if args.json:
        print_json(user)
    else:
        print(f"id      : {user.get('id')}")
        print(f"username: {user.get('username')}")
        print(f"name    : {user.get('full_name') or user.get('name') or ''}")


def cmd_projects(_args: argparse.Namespace) -> None:
    print_json([{"id": p.get("id"), "name": p.get("name"), "slug": p.get("slug")} for p in client().projects()])


def cmd_statuses(args: argparse.Namespace) -> None:
    kind = canonical_kind(args.kind or DEFAULT_KIND)
    print_json([{"id": s.get("id"), "name": s.get("name"), "slug": s.get("slug"), "order": s.get("order")} for s in client().statuses(kind, args.project_id)])


def cmd_members(args: argparse.Namespace) -> None:
    print_json([{"id": m.get("id"), "username": m.get("username"), "name": m.get("full_name") or m.get("name")} for m in client().members(args.project_id)])


def cmd_get(args: argparse.Namespace) -> None:
    kind = resolved_kind(args)
    item = client().resolve_ref(kind, args.ref, args.project_id)
    print_json(item if args.full else compact_entity(item, kind=kind))


def cmd_list(args: argparse.Namespace) -> None:
    c = client()
    kind = resolved_kind(args)
    items = c.search_entities(kind, subject=args.subject, contains=args.contains, project_id=args.project_id, limit=args.limit)
    print_json([compact_entity(item, kind=kind) for item in items])


def cmd_find(args: argparse.Namespace) -> None:
    c = client()
    kind = resolved_kind(args)
    items = c.search_entities(kind, subject=args.subject, contains=args.contains, project_id=args.project_id, limit=args.limit)
    print_json({"count": len(items), "matches": [compact_entity(item, kind=kind) for item in items]})


def all_kinds_for_tags(kind: str | None) -> list[str]:
    if not kind or kind == "all":
        return ["userstories", "tasks", "issues"]
    return [canonical_kind(kind)]


def collect_tags(c: TaigaClient, kinds: list[str], project_id: int | None = None) -> Counter[str]:
    counter: Counter[str] = Counter()
    for kind in kinds:
        for item in c.list_entities(kind, project_id):
            for tag in item.get("tags") or []:
                normalized = normalize_tag(tag)
                if normalized:
                    counter[normalized] += 1
    return counter


def cmd_tags(args: argparse.Namespace) -> None:
    c = client()
    counter = collect_tags(c, all_kinds_for_tags(args.kind), args.project_id)
    items = [{"name": name, "count": count} for name, count in counter.most_common()]
    if args.contains:
        needle = args.contains.lower()
        items = [item for item in items if needle in item["name"].lower()]
    if args.limit:
        items = items[:args.limit]
    print_json({"count": len(items), "tags": items})


def cmd_suggest_tags(args: argparse.Namespace) -> None:
    text = args.text or ""
    if args.text_stdin:
        text = read_stdin_text("texto para sugerir tags")
    text = f"{args.subject or ''}\n{text}".lower()
    c = client()
    counter = collect_tags(c, all_kinds_for_tags(args.kind), args.project_id)
    existing = [name for name in counter if name.lower() in text]
    candidate_pool = re.findall(r"[a-zA-ZÀ-ÿ0-9_\-]{3,}", text)
    candidates: list[str] = []
    stop = {"para", "como", "com", "dos", "das", "uma", "por", "que", "the", "and", "pipeline", "tabela"}
    for token in candidate_pool:
        token = token.strip("_-.").lower().replace("_", "-")
        if token and token not in stop and token not in candidates and token not in [x.lower() for x in existing]:
            candidates.append(token)
    print_json({"existing_matches": sorted(existing), "new_candidates": candidates[:10]})


def build_base_payload(c: TaigaClient, args: argparse.Namespace, canonical: str, project_id: int, description: str) -> tuple[dict[str, Any], dict[str, Any]]:
    payload: dict[str, Any] = {"project": project_id, "subject": args.subject, "description": description, "tags": args.tag or []}
    preview = dict(payload)
    if canonical == "tasks" and getattr(args, "userstory_ref", None):
        us = c.resolve_ref("userstory", args.userstory_ref, project_id)
        payload["user_story"] = us["id"]
        preview["user_story"] = f"#{us.get('ref')} — {us.get('subject')}"
    apply_default_management_fields(c, args, canonical, project_id, payload, preview)
    return payload, preview


def cmd_create(args: argparse.Namespace) -> None:
    c = client()
    canonical = resolved_kind(args)
    project_id = c.project_id(args.project_id)
    if args.description_stdin:
        description = read_stdin_text("descrição")
    elif args.description_file:
        description = Path(args.description_file).read_text(encoding="utf-8")
    else:
        description = args.description or ""
    payload, preview = build_base_payload(c, args, canonical, project_id, description)
    if args.dry_run:
        dry_run_output("create", canonical, payload=preview, json_output=args.json)
        return
    require_yes(args, "create")
    print_json({"created": compact_entity(c.create_entity(canonical, payload), kind=canonical), "kind": public_kind(canonical)})


def parse_task_line(line: str) -> tuple[str, str]:
    clean = line.strip()
    clean = re.sub(r"^[-*]\s+", "", clean)
    if not clean:
        return "", ""
    for sep in [" | ", " :: ", " — ", " - "]:
        if sep in clean:
            subject, description = clean.split(sep, 1)
            return subject.strip(), description.strip()
    return clean, ""


def parse_tasks_input(args: argparse.Namespace) -> list[dict[str, str]]:
    raw_items = list(args.task or [])
    if args.tasks_stdin:
        raw_items.extend(read_stdin_text("tasks").splitlines())
    tasks = []
    for line in raw_items:
        subject, description = parse_task_line(line)
        if subject:
            tasks.append({"subject": subject, "description": description})
    if not tasks:
        die("nenhuma task informada; use --task ou --tasks-stdin")
    return tasks


def cmd_create_tasks(args: argparse.Namespace) -> None:
    c = client()
    project_id = c.project_id(args.project_id)
    userstory = c.resolve_ref("userstory", args.userstory_ref, project_id)
    tasks = parse_tasks_input(args)
    payloads: list[dict[str, Any]] = []
    previews: list[dict[str, Any]] = []
    for item in tasks:
        task_args = argparse.Namespace(**vars(args))
        task_args.subject = item["subject"]
        payload = {
            "project": project_id,
            "user_story": userstory["id"],
            "subject": item["subject"],
            "description": item["description"],
            "tags": args.tag or [],
        }
        preview = {
            "user_story": f"#{userstory.get('ref')} — {userstory.get('subject')}",
            "subject": item["subject"],
            "description": item["description"],
            "tags": args.tag or [],
        }
        apply_default_management_fields(c, task_args, "tasks", project_id, payload, preview)
        payloads.append(payload)
        previews.append(preview)
    target = compact_entity(userstory, kind="userstory")
    if args.dry_run:
        dry_run_output("create-tasks", "task", target=target, payload=previews, json_output=args.json)
        return
    require_yes(args, "create-tasks")
    created = [compact_entity(c.create_entity("task", payload), kind="task") for payload in payloads]
    print_json({"created_count": len(created), "userstory": target, "tasks": created})


def cmd_comment(args: argparse.Namespace) -> None:
    if args.text_stdin:
        text = read_stdin_text("comentário")
    elif args.text_file:
        text = Path(args.text_file).read_text(encoding="utf-8")
    else:
        text = args.text or ""
    if not text.strip():
        die("comentário vazio")
    c = client()
    canonical = resolved_kind(args)
    item = c.resolve_ref(canonical, args.ref, args.project_id)
    payload = {"comment": text}
    target = compact_entity(item, kind=canonical)
    if args.dry_run:
        dry_run_output("comment", canonical, target=target, payload=payload, json_output=args.json)
        return
    require_yes(args, "comment")
    print_json({"commented": compact_entity(c.patch_entity(canonical, int(item["id"]), payload), kind=canonical), "kind": public_kind(canonical)})


def cmd_update(args: argparse.Namespace) -> None:
    c = client()
    canonical = resolved_kind(args)
    item = c.resolve_ref(canonical, args.ref, args.project_id)
    project_id = c.project_id(args.project_id)
    payload: dict[str, Any] = {}
    preview: dict[str, Any] = {}
    if args.subject:
        payload["subject"] = args.subject
        preview["subject"] = args.subject
    if args.description_stdin:
        payload["description"] = read_stdin_text("descrição")
        preview["description"] = payload["description"]
    elif args.description_file:
        payload["description"] = Path(args.description_file).read_text(encoding="utf-8")
        preview["description"] = payload["description"]
    elif args.description is not None:
        payload["description"] = args.description
        preview["description"] = args.description
    if args.status:
        status_id, status_label = c.resolve_status(canonical, args.status, project_id)
        payload["status"] = status_id
        preview["status"] = status_label
    if args.assigned_to:
        payload["assigned_to"] = c.resolve_member(args.assigned_to, project_id)
        preview["assigned_to"] = args.assigned_to
    if args.no_assignee:
        payload["assigned_to"] = None
        preview["assigned_to"] = "—"
    if args.due_date or args.no_due_date:
        payload["due_date"] = parse_due_date(args.due_date, no_due_date=args.no_due_date)
        preview["due_date"] = payload["due_date"] or "—"
    if args.tag:
        payload["tags"] = args.tag
        preview["tags"] = args.tag
    if not payload:
        die("nada para atualizar")
    target = compact_entity(item, kind=canonical)
    if args.dry_run:
        dry_run_output("update", canonical, target=target, payload=preview, json_output=args.json)
        return
    require_yes(args, "update")
    print_json({"updated": compact_entity(c.patch_entity(canonical, int(item["id"]), payload), kind=canonical), "kind": public_kind(canonical)})


def maturity_findings(entity: dict[str, Any]) -> list[dict[str, str]]:
    subject = str(entity.get("subject") or "").strip()
    description = str(entity.get("description") or "").strip()
    text = f"{subject}\n{description}".lower()
    checks = [
        ("objetivo", bool(subject and len(subject) >= 8), "título/objetivo claro"),
        ("escopo", any(w in text for w in ["escopo", "scope", "deve", "implementar", "entregar"]), "escopo descrito"),
        ("valor", any(w in text for w in ["para que", "valor", "benefício", "beneficio", "resultado"]), "valor/resultado esperado"),
    ]
    return [{"name": name, "status": "ok" if ok else "missing", "description": desc} for name, ok, desc in checks]


def cmd_maturity(args: argparse.Namespace) -> None:
    canonical = resolved_kind(args)
    entity = client().resolve_ref(canonical, args.ref, args.project_id)
    findings = maturity_findings(entity)
    missing = [item for item in findings if item["status"] != "ok"]
    print_json({"ref": entity.get("ref"), "id": entity.get("id"), "subject": entity.get("subject"), "ready_for_work": not missing, "checks": findings, "recommendation": "pronta para trabalho" if not missing else "refinar antes do trabalho"})


def repo_root() -> Path:
    code, out = command_output(["git", "rev-parse", "--show-toplevel"])
    if code != 0:
        die("rode dentro de um repositório git para usar vínculo com Wave")
    return Path(out)


def wave_path(wave_id: str) -> Path:
    return repo_root() / ".opencode" / "waves" / wave_id / "wave.json"


def read_wave(wave_id: str) -> dict[str, Any]:
    return read_json(wave_path(wave_id), None)


def write_wave(wave_id: str, wave: dict[str, Any]) -> None:
    write_json(wave_path(wave_id), wave)


def cmd_link(args: argparse.Namespace) -> None:
    wave = read_wave(args.wave)
    config = load_config(True)
    kind = public_kind(canonical_kind(args.kind or DEFAULT_KIND))
    taiga = {"enabled": True, "ref": args.ref, "kind": kind, "project_id": int(args.project_id or config.get("project_id")), "auto_sync": not args.no_auto_sync, "created_by_tide": args.created_by_tide, "last_sync": None}
    wave["taiga"] = taiga
    write_wave(args.wave, wave)
    print_json({"linked": args.wave, "taiga": taiga})


def wave_summary(wave: dict[str, Any]) -> str:
    lines = [f"Status: {wave.get('status', 'unknown')}", f"Título: {wave.get('title', '')}"]
    if wave.get("result"):
        lines.extend(["", "Resumo:", f"- {wave.get('result')}"])
    validations = wave.get("validations") or []
    if validations:
        lines.extend(["", "Validação:"])
        for item in validations[-3:]:
            if isinstance(item, dict):
                details = " — ".join(str(v) for v in [item.get("summary"), item.get("result")] if v)
                lines.append(f"- {details}")
                if item.get("command"):
                    lines.append(f"  comando: {item.get('command')}")
            else:
                lines.append(f"- {item}")
    if wave.get("status") == "committed":
        code, out = command_output(["git", "log", "-1", "--oneline"])
        if code == 0 and out:
            lines.extend(["", "Commit:", f"- {out}"])
    return "\n".join(lines).strip() + "\n"


def cmd_sync(args: argparse.Namespace) -> None:
    wave = read_wave(args.wave)
    taiga = wave.get("taiga") or {}
    if not taiga and not args.ref:
        die("Wave sem vínculo Taiga; use `tide taiga link` ou informe --ref/--kind")
    ref = args.ref or int(taiga.get("ref"))
    kind = args.kind or taiga.get("kind") or DEFAULT_KIND
    text = args.text or wave_summary(wave)
    c = client()
    item = c.resolve_ref(kind, int(ref), args.project_id or taiga.get("project_id"))
    payload = {"comment": text}
    target = compact_entity(item, kind=kind)
    if args.dry_run:
        dry_run_output("sync-comment", kind, target=target, payload=payload, note=f"Wave local: {args.wave}", json_output=args.json)
        return
    require_yes(args, "sync")
    updated = c.patch_entity(kind, int(item["id"]), payload)
    taiga.update({"enabled": True, "ref": int(ref), "kind": public_kind(canonical_kind(kind)), "last_sync": datetime.now().astimezone().isoformat(timespec="seconds")})
    wave["taiga"] = taiga
    write_wave(args.wave, wave)
    print_json({"synced": args.wave, "taiga": taiga, "item": compact_entity(updated, kind=kind)})


def description_from_wave(wave: dict[str, Any]) -> str:
    intent = str(wave.get("intent") or wave.get("title") or "realizar ajuste solicitado").strip()
    return f"**EU QUERO** {intent}.\n**COMO** time responsável pelo domínio afetado.\n**PARA QUE** a entrega seja registrada e acompanhada no board.\n"


def cmd_create_from_wave(args: argparse.Namespace) -> None:
    wave = read_wave(args.wave)
    c = client()
    canonical = resolved_kind(args)
    payload, preview = build_base_payload(c, argparse.Namespace(**{**vars(args), "subject": args.subject or wave.get("title") or args.wave, "userstory_ref": None}), canonical, c.project_id(args.project_id), description_from_wave(wave))
    if args.dry_run:
        dry_run_output("create-from-wave", canonical, payload=preview, note=f"Wave local: {args.wave}", json_output=args.json)
        return
    require_yes(args, "create-from-wave")
    created = c.create_entity(canonical, payload)
    ref = int(created.get("ref") or created.get("id"))
    taiga = {"enabled": True, "ref": ref, "kind": public_kind(canonical_kind(canonical)), "project_id": c.project_id(args.project_id), "auto_sync": True, "created_by_tide": True, "last_sync": None}
    wave["taiga"] = taiga
    write_wave(args.wave, wave)
    print_json({"created": compact_entity(created, kind=canonical), "linked": args.wave, "taiga": taiga})


def add_kind_arg(parser: argparse.ArgumentParser) -> None:
    parser.add_argument("--kind", choices=["board", "userstory", "task", "issue"], default=DEFAULT_KIND)


def add_management_args(parser: argparse.ArgumentParser) -> None:
    parser.add_argument("--status", help="status exato ou alias: doing, done, todo")
    parser.add_argument("--no-status", action="store_true", help="não define status inicial/default")
    parser.add_argument("--assigned-to", help="username/nome do responsável; default: usuário atual")
    parser.add_argument("--no-assignee", action="store_true", help="não associa responsável")
    parser.add_argument("--due-date", help="today, none ou YYYY-MM-DD; default: today")
    parser.add_argument("--no-due-date", action="store_true", help="não define due_date")


def add_write_guard_args(parser: argparse.ArgumentParser) -> None:
    parser.add_argument("--dry-run", action="store_true", help="mostra o que seria alterado, sem escrever no Taiga")
    parser.add_argument("--yes", action="store_true", help="confirma escrita no Taiga após aprovação explícita")
    parser.add_argument("--json", action="store_true", help="no dry-run, imprime JSON bruto em vez de preview legível")


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(prog="tide taiga", description="Integração opcional Tide ↔ Taiga")
    sub = parser.add_subparsers(dest="command")
    p = sub.add_parser("configure"); p.add_argument("--base-url"); p.add_argument("--project-id", type=int); p.add_argument("--default-kind", choices=["userstory", "task", "issue"], default=DEFAULT_KIND); p.add_argument("--token"); p.add_argument("--allow-local-token", action="store_true"); p.set_defaults(func=cmd_configure)
    sub.add_parser("doctor").set_defaults(func=cmd_doctor); sub.add_parser("show").set_defaults(func=cmd_show); sub.add_parser("logout").set_defaults(func=cmd_logout)
    p = sub.add_parser("whoami"); p.add_argument("--json", action="store_true"); p.set_defaults(func=cmd_whoami)
    sub.add_parser("projects").set_defaults(func=cmd_projects)
    p = sub.add_parser("statuses"); add_kind_arg(p); p.add_argument("--project-id", type=int); p.set_defaults(func=cmd_statuses)
    p = sub.add_parser("members"); p.add_argument("--project-id", type=int); p.set_defaults(func=cmd_members)
    p = sub.add_parser("tags"); p.add_argument("--kind", choices=["all", "userstory", "task", "issue"], default="all"); p.add_argument("--contains"); p.add_argument("--limit", type=int); p.add_argument("--project-id", type=int); p.set_defaults(func=cmd_tags)
    p = sub.add_parser("suggest-tags"); p.add_argument("--kind", choices=["all", "userstory", "task", "issue"], default="all"); p.add_argument("--subject"); p.add_argument("--text"); p.add_argument("--text-stdin", action="store_true"); p.add_argument("--project-id", type=int); p.set_defaults(func=cmd_suggest_tags)
    p = sub.add_parser("get"); add_kind_arg(p); p.add_argument("--ref", type=int, required=True); p.add_argument("--project-id", type=int); p.add_argument("--full", action="store_true"); p.set_defaults(func=cmd_get)
    p = sub.add_parser("list"); add_kind_arg(p); p.add_argument("--project-id", type=int); p.add_argument("--subject"); p.add_argument("--contains"); p.add_argument("--limit", type=int); p.set_defaults(func=cmd_list)
    p = sub.add_parser("find"); add_kind_arg(p); p.add_argument("--subject"); p.add_argument("--contains"); p.add_argument("--project-id", type=int); p.add_argument("--limit", type=int); p.set_defaults(func=cmd_find)
    p = sub.add_parser("create"); add_kind_arg(p); p.add_argument("--subject", required=True); p.add_argument("--description", default=""); p.add_argument("--description-file"); p.add_argument("--description-stdin", action="store_true"); p.add_argument("--project-id", type=int); p.add_argument("--userstory-ref", type=int); p.add_argument("--tag", action="append"); add_management_args(p); add_write_guard_args(p); p.set_defaults(func=cmd_create)
    p = sub.add_parser("create-tasks"); p.add_argument("--userstory-ref", type=int, required=True); p.add_argument("--task", action="append", help="task em formato 'Título' ou 'Título | descrição'"); p.add_argument("--tasks-stdin", action="store_true"); p.add_argument("--project-id", type=int); p.add_argument("--tag", action="append"); add_management_args(p); add_write_guard_args(p); p.set_defaults(func=cmd_create_tasks)
    p = sub.add_parser("comment"); add_kind_arg(p); p.add_argument("--ref", type=int, required=True); p.add_argument("--text", default=""); p.add_argument("--text-file"); p.add_argument("--text-stdin", action="store_true"); p.add_argument("--project-id", type=int); add_write_guard_args(p); p.set_defaults(func=cmd_comment)
    p = sub.add_parser("update"); add_kind_arg(p); p.add_argument("--ref", type=int, required=True); p.add_argument("--subject"); p.add_argument("--description"); p.add_argument("--description-file"); p.add_argument("--description-stdin", action="store_true"); p.add_argument("--project-id", type=int); p.add_argument("--tag", action="append"); add_management_args(p); add_write_guard_args(p); p.set_defaults(func=cmd_update)
    p = sub.add_parser("maturity"); add_kind_arg(p); p.add_argument("--ref", type=int, required=True); p.add_argument("--project-id", type=int); p.set_defaults(func=cmd_maturity)
    p = sub.add_parser("link"); p.add_argument("wave"); p.add_argument("--ref", type=int, required=True); add_kind_arg(p); p.add_argument("--project-id", type=int); p.add_argument("--created-by-tide", action="store_true"); p.add_argument("--no-auto-sync", action="store_true"); p.set_defaults(func=cmd_link)
    p = sub.add_parser("sync"); p.add_argument("wave"); p.add_argument("--ref", type=int); add_kind_arg(p); p.add_argument("--project-id", type=int); p.add_argument("--text"); add_write_guard_args(p); p.set_defaults(func=cmd_sync)
    p = sub.add_parser("create-from-wave"); p.add_argument("wave"); add_kind_arg(p); p.add_argument("--subject"); p.add_argument("--project-id", type=int); p.add_argument("--tag", action="append"); add_management_args(p); add_write_guard_args(p); p.set_defaults(func=cmd_create_from_wave)
    return parser


def main(argv: list[str] | None = None) -> None:
    parser = build_parser()
    args = parser.parse_args(argv)
    if not hasattr(args, "func"):
        parser.print_help()
        return
    args.func(args)


if __name__ == "__main__":
    main()
